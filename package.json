{
  "name": "@aztec/mcp-server",
  "version": "1.6.0",
  "description": "MCP server for Aztec development - clones and searches Aztec documentation and examples",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aztec-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "aztec",
    "mcp",
    "model-context-protocol",
    "noir",
    "blockchain",
    "privacy",
    "smart-contracts"
  ],
  "author": "critesjosh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aztecprotocol/mcp-server"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "globby": "^14.0.2",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/node": "^22.10.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
